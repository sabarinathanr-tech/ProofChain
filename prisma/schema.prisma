generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  OWNER
  ADMIN
  PROCUREMENT
  WAREHOUSE
  FINANCE
  VIEWER
}

enum WorkStatus {
  DRAFT
  IN_TRANSIT
  DELIVERED
  PROCESSING
  VERIFIED
  EXCEPTION
  OPEN
  RESOLVED
}

model Company {
  id          String     @id @default(cuid())
  name        String
  industry    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]
  vendors     Vendor[]
  warehouses  Warehouse[]
  purchaseOrders PurchaseOrder[]
  shipments   Shipment[]
  disputes    Dispute[]
  notifications Notification[]
  reports     Report[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      RoleName @default(VIEWER)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  activities ActivityLog[]
}

model Vendor {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  reliability Int      @default(90)
  averageDelay Float   @default(0)
  damageRate  Float    @default(0)
  preferred   Boolean  @default(false)
  purchaseOrders PurchaseOrder[]
  shipments   Shipment[]
  disputes    Dispute[]
}

model Warehouse {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  location  String
  shipments Shipment[]
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  code            String   @unique
  companyId       String
  vendorId        String
  expectedDelivery DateTime
  status          WorkStatus @default(DRAFT)
  documentUrl     String?
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  items           PurchaseOrderItem[]
  shipments       Shipment[]
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  sku             String
  description     String
  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id              String @id @default(cuid())
  code            String @unique
  companyId       String
  purchaseOrderId String
  vendorId        String
  warehouseId     String?
  carrier         String
  trackingNumber  String?
  status          WorkStatus @default(PROCESSING)
  risk            String @default("Medium")
  expectedArrival DateTime
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  vendor          Vendor @relation(fields: [vendorId], references: [id])
  warehouse       Warehouse? @relation(fields: [warehouseId], references: [id])
  items           ShipmentItem[]
  inspections     WarehouseInspection[]
  invoices        Invoice[]
  analyses        AIAnalysis[]
  disputes        Dispute[]
}

model ShipmentItem {
  id         String @id @default(cuid())
  shipmentId String
  sku        String
  expectedQuantity Int
  receivedQuantity Int @default(0)
  damagedQuantity Int @default(0)
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model WarehouseInspection {
  id         String @id @default(cuid())
  shipmentId String
  receivedQuantity Int
  damagedQuantity Int @default(0)
  missingQuantity Int @default(0)
  extraQuantity Int @default(0)
  notes      String?
  status     WorkStatus @default(PROCESSING)
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  photos     InspectionPhoto[]
}

model InspectionPhoto {
  id           String @id @default(cuid())
  inspectionId String
  url          String
  caption      String?
  inspection   WarehouseInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String @id @default(cuid())
  shipmentId String
  number     String
  total      Decimal @db.Decimal(12, 2)
  documentUrl String?
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model AIAnalysis {
  id          String @id @default(cuid())
  shipmentId  String
  confidence  Int
  summary     String
  findings    Json
  createdAt   DateTime @default(now())
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Dispute {
  id          String @id @default(cuid())
  code        String @unique
  companyId   String
  shipmentId  String
  vendorId    String
  reason      String
  status      WorkStatus @default(OPEN)
  valueAtRisk Decimal @db.Decimal(12, 2)
  aiSummary   String?
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shipment    Shipment @relation(fields: [shipmentId], references: [id])
  vendor      Vendor @relation(fields: [vendorId], references: [id])
  evidence    Evidence[]
}

model Evidence {
  id        String @id @default(cuid())
  disputeId String
  type      String
  url       String?
  notes     String?
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String @id @default(cuid())
  companyId String
  title     String
  body      String
  severity  String
  read      Boolean @default(false)
  createdAt DateTime @default(now())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        String @id @default(cuid())
  companyId String
  name      String
  type      String
  url       String?
  createdAt DateTime @default(now())
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id        String @id @default(cuid())
  companyId String
  period    String
  metrics   Json
  createdAt DateTime @default(now())
}
